# ─────────────────────────────────────────────────────────────────────────
# AuraGrowth Backend – Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────
APP_NAME=AuraGrowth
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────
# Internal Render URL (use this for deployment):
DATABASE_URL=postgresql+asyncpg://linkshare_h09n_user:qJ73O9KqtxClUjBji3prbzXzkjGyQRIJ@dpg-d7mebq9j2pic73caljng-a/linkshare_h09n

# External Render URL (use this for local development/migrations):
# DATABASE_URL=postgresql+asyncpg://linkshare_h09n_user:qJ73O9KqtxClUjBji3prbzXzkjGyQRIJ@dpg-d7mebq9j2pic73caljng-a.oregon-postgres.render.com/linkshare_h09n

# ── JWT ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth (for login + Gmail) ─────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── Meta / Instagram ─────────────────────────────────────────────────────
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/v1/instagram/callback

# ── SMTP / Email ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=AuraGrowth
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=true

# ── Rate Limiting ────────────────────────────────────────────────────────
IG_DM_RATE_LIMIT_PER_DAY=200
